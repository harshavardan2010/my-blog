---
layout: base.njk
---
<article class="log-entry">
    <div class="entry-meta">
        <span class="entry-id">RECORD</span>
        <span>{{ date | blogdate }}</span>
        <span>[{{ category | upper }}]</span>
    </div>
    <h2 class="entry-title">{{ title }}</h2>
    <div class="post-content" style="margin-top: 16px;">
        {{ content | safe }}
    </div>
    <a href="/" class="action-btn" style="margin-top: 24px;">← Back to Logs</a>
</article>
